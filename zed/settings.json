{
  "ui_font_family": ".SystemUIFont",
  "buffer_font_family": "GeistMono Nerd Font Mono",
  "cli_default_open_behavior": "existing_window",
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
    "opencode": {
      "favorite_config_option_values": {
        "model": [
          "ollama-cloud/minimax-m2.7",
          "ollama-cloud/kimi-k2.5",
          "ollama-cloud/glm-5.1",
          "openai/gpt-5.4-mini",
          "openai/gpt-5.4",
          "opencode/ling-2.6-flash-free",
        ],
      },
      "type": "registry",
    },
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
  },
  "lsp_document_colors": "none",
  "theme": {
    "mode": "dark",
    "light": "Cursor Dark",
    "dark": "Flexoki Dark",
  },
  "zoomed_padding": true,
  "tabs": {
    "show_close_button": "hover",
    "close_position": "right",
    "git_status": false,
    "file_icons": true,
  },
  "tab_bar": {
    "show_tab_bar_buttons": true,
    "show_nav_history_buttons": false,
    "show": true,
  },
  "disable_ai": true,
  "show_edit_predictions": false,
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "rounded_selection": true,
  "always_treat_brackets_as_autoclosed": true,
  "edit_predictions": {
    "provider": "none",
    "mode": "subtle",
  },
  "collaboration_panel": {
    "dock": "right",
    "default_width": 300.0,
    "button": true,
  },
  "notification_panel": {
    "button": false,
  },
  "git_panel": {
    "dock": "right",
    "default_width": 400.0,
    "button": false,
  },
  "outline_panel": {
    "dock": "right",
    "default_width": 400.0,
    "indent_guides": {
      "show": "never",
    },
    "auto_fold_dirs": true,
    "file_icons": true,
    "button": false,
  },
  "bottom_dock_layout": "contained",
  "file_finder": {
    "file_icons": true,
  },
  "title_bar": {
    "show_menus": false,
    "show_sign_in": false,
    "show_user_picture": false,
    "show_onboarding_banner": false,
    "show_project_items": false,
    "show_branch_name": false,
  },
  "debugger": {
    "button": false,
  },
  "search": {
    "button": true,
  },
  "diagnostics": {
    "button": false,
  },
  "terminal": {
    "show_count_badge": false,
    "flexible": true,
    "scrollbar": {
      "show": "never",
    },
    "toolbar": {
      "breadcrumbs": false,
    },
    "default_width": 320.0,
    "copy_on_select": true,
    "minimum_contrast": 0.0,
    "blinking": "off",
    "font_size": 16.0,
    "dock": "bottom",
    "button": true,
    "cursor_shape": "bar",
  },
  "status_bar": {
    "cursor_position_button": false,
    "active_language_button": false,
  },
  "agent_buffer_font_size": 16.0,
  "agent": {
    "default_height": 300.0,
    "default_width": 300.0,
    "dock": "left",
    "tool_permissions": {
      "default": "allow",
    },
    "default_model": {
      "effort": "low",
      "enable_thinking": false,
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
    },
    "default_profile": "write",
    "model_parameters": [],
  },
  "soft_wrap": "editor_width",
  "tab_size": 2,
  "toolbar": {
    "agent_review": false,
    "selections_menu": false,
    "quick_actions": false,
    "breadcrumbs": false,
  },
  "scrollbar": {
    "axes": {
      "vertical": true,
      "horizontal": false,
    },
  },
  "gutter": {
    "breakpoints": false,
    "folds": false,
    "line_numbers": true,
  },
  "show_wrap_guides": false,
  "indent_guides": {
    "enabled": false,
  },
  "project_panel": {
    "git_status_indicator": false,
    "bold_folder_labels": false,
    "dock": "left",
    "hide_hidden": false,
    "hide_root": false,
    "indent_guides": {
      "show": "never",
    },
    "scrollbar": {
      "show": "never",
    },
    "auto_fold_dirs": true,
    "auto_reveal_entries": true,
    "git_status": true,
    "folder_icons": true,
    "file_icons": true,
    "entry_spacing": "comfortable",
    "hide_gitignore": false,
    "default_width": 300.0,
    "button": true,
  },
  "cursor_shape": "bar",
  "cursor_blink": false,
  "restore_on_startup": "launchpad",
  "base_keymap": "VSCode",
  "ui_font_size": 16.0,
  "buffer_font_size": 16.0,
  "auto_indent": "syntax_aware",
  "auto_indent_on_paste": true,
  "autosave": {
    "after_delay": {
      "milliseconds": 100,
    },
  },
  "autoscroll_on_clicks": true,
  "text_rendering_mode": "platform_default",
}
