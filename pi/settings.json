{
  "lastChangelogVersion": "0.80.10",
  "theme": "terminal",
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.6-sol",
  "defaultThinkingLevel": "medium",
  "packages": [
    "npm:pi-subagents",
    "npm:pi-web-access",
    "npm:pi-lens",
    "npm:pi-terminal-theme"
  ],
  "subagents": {
    "defaultModel": "gpt-5.6-luna",
    "agentOverrides": {
      "scout": { "model": "gpt-5.6-luna", "thinking": "low" },
      "context-builder": { "model": "gpt-5.6-terra", "thinking": "low" },
      "researcher": { "model": "gpt-5.6-terra", "thinking": "medium" },
      "delegate": { "model": "gpt-5.6-terra", "thinking": "medium" },
      "reviewer": { "model": "gpt-5.6-terra", "thinking": "medium" },
      "worker": { "model": "gpt-5.6-sol", "thinking": "medium" },
      "planner": { "model": "gpt-5.6-sol", "thinking": "high" },
      "oracle": { "model": "gpt-5.6-sol", "thinking": "high" }
    }
  }
}
