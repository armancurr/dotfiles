font-family             = GeistMono Nerd Font Mono
font-family-bold        = GeistMono Nerd Font Mono
font-family-italic      = GeistMono Nerd Font Mono
font-family-bold-italic = GeistMono Nerd Font Mono
font-size = 16

theme = Flexoki Dark

cursor-style       = bar
cursor-style-blink = false

mouse-shift-capture     = true
mouse-scroll-multiplier = 5

maximize = true

window-vsync                     = true
window-inherit-working-directory = true
window-inherit-font-size         = true
window-subtitle                  = false
window-theme                     = ghostty
window-save-state                = never
window-new-tab-position          = end
window-show-tab-bar              = never
window-titlebar-background       = #000000

clipboard-read                 = allow
clipboard-write                = allow
clipboard-trim-trailing-spaces = true
clipboard-paste-protection     = true

copy-on-select = true

right-click-action = context-menu

click-repeat-interval = 300

auto-update         = check
auto-update-channel = stable
