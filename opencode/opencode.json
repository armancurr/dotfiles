{
  "$schema": "https://opencode.ai/config.json",
  "theme": "cursor",
  "agent": {
    "explore": {
      "model": "openai/gpt-5.4-mini"
    },
    "general": {
      "model": "openai/gpt-5.4-mini"
    }
  },
  "tui": {
    "scroll_speed": 10,
    "scroll_acceleration": {
      "enabled": true
    }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["bunx", "-y", "chrome-devtools-mcp@latest"]
    }
  }
}
